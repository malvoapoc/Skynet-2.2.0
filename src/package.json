{
    "name": "Skynet",
    "version": "2.1.8",
    "description": "Skynet For Windows",
    "main": "src/main/main.js",
    "repository": "",
    "author": "",
    "license": "Apache-2.0",
    "build": {
        "productName": "BestSSR",
        "appId": "com.Skynet.Maker",
        "copyright": "©2026 Skynet, Inc.",
        "extraResources": [
            {
                "from": "../libs/win32",
                "to": "./extra"
            },
            {
                "from": "../libs/elevate.exe",
                "to": "./"
            }
        ],
        "win": {
            "icon": "../res/icon.ico",
            "requestedExecutionLevel": "highestAvailable",
            "target": [
                "nsis"
            ]
        },
        "nsis": {
            "oneClick": false,
            "perMachine": true,
            "allowElevation": true,
            "allowToChangeInstallationDirectory": true
        }
    },
    "dependencies": {
        "bluebird": "^3.7.2",
        "child_process": "^1.0.2",
        "crypto-js": "^4.2.0",
        "electron-updater": "^6.6.2",
        "fs-extra": "^10.1.0",
        "http": "0.0.1-security",
        "path": "^0.12.7",
        "request": "^2.88.2",
        "sudo-prompt": "^9.2.1",
        "tracer": "^1.1.6"
    },
    "devDependencies": {
        "electron": "^11.0.0",
        "electron-builder": "^24.12.0"
    }
}