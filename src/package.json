{
    "name": "Skynet",
    "version": "2.1.8",
    "description": "智连云 For Windows",
    "main": "src/main/main.js",
    "repository": "",
    "author": "",
    "license": "Apache-2.0",
    "productName": "智连云",
    "build": {
        "productName": "智连云",
        "extraResources": [
            {
                "from": "../libs/win32",
                "to": "./extra"
            },
            {
                "from": "../libs/elevate.exe",
                "to": "./"
            }
        ],
        "win": {
            "icon": "../res/icon.ico",
			"requestedExecutionLevel": "highestAvailable",
            "target": [
                "nsis"
            ]
        },
        "nsis": {
            "oneClick": false,
            "perMachine": true,
            "allowToChangeInstallationDirectory": true
        }
    },
    "dependencies": {
        "bluebird": "^3.7.2",
        "child_process": "^1.0.2",
        "default-gateway": "^6.0.0",
        "electron-notarize": "^1.2.1",
        "electron-updater": "^5.2.1",
        "fs-extra": "^10.1.0",
        "http": "0.0.1-security",
        "js-yaml": "^4.0.0",
        "path": "^0.12.7",
        "ping": "^0.2.3",
        "request": "^2.88.2",
        "sudo-prompt": "^9.2.1",
        "tcp-ping": "^0.1.1",
        "tracer": "^1.1.6"
    },
    "devDependencies": {
        "electron": "^11.0.0",
        "electron-builder": "^24.12.0"
    }
}